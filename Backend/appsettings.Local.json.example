{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=bilgeproje;Username=bilgeproje_user;Password=password"
  },
  "JWT": {
    "Key": "RUN_IN_POWERSHELL: $b=New-Object byte[] 32; (New-Object System.Security.Cryptography.RNGCryptoServiceProvider).GetBytes($b); [Convert]::ToBase64String($b)",
    "Issuer": "BilgeProje",
    "Audience": "BilgeProjeClient",
    "ExpiryInMinutes": 60
  }
}
